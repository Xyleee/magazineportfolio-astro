---
// src/pages/index.astro
// =====================
// Single-page magazine-style portfolio.
// Import your components here. Add or rearrange sections freely.

import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

// Portfolio sections — import all components
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import TechStack from '../components/TechStack.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Awards from '../components/Awards.astro';
import Community from '../components/Community.astro';
import Hobbies from '../components/Hobbies.astro';
import FunFacts from '../components/FunFacts.astro';
import Footer from '../components/Footer.astro';
---

<!--
  PORTFOLIO PAGE
  ==============
  All content is in the individual component files inside src/components/.
  Search for "// EDIT" comments throughout to find all placeholder text.
-->

<Layout
  title="Alex Dev — Portfolio"
  description="Full-stack developer crafting delightful web experiences. Magazine-style portfolio."
>
  <!-- Sticky top nav -->
  <Navbar />

  <!-- Main content -->
  <main>
    <!-- 1. Hero — headline, intro, CTA buttons -->
    <Hero />

    <!-- 2. About Me — bio, pull quote, quick facts -->
    <About />

    <!-- 3. Tech Stack — grid of tools and technologies -->
    <TechStack />

    <!-- 4. Skills — categorized skill pills -->
    <Skills />

    <!-- 5. Projects — card grid of shipped work -->
    <Projects />

    <!-- 6. Awards & Achievements — timeline -->
    <Awards />

    <!-- 7. Community & Open Source — card grid -->
    <Community />

    <!-- 8. Hobbies — lifestyle section -->
    <Hobbies />

    <!-- 9. Fun Facts — quirky grid -->
    <FunFacts />
  </main>

  <!-- Footer — contact CTA + social links -->
  <Footer />
</Layout>
