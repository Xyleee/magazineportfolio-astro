---
// Footer.astro — Editorial footer
// EDIT: Your name, email, and social links

const socials = [
  {
    label: "GitHub",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.387.6.11.82-.258.82-.577v-2.165c-3.338.726-4.043-1.415-4.043-1.415-.546-1.387-1.333-1.757-1.333-1.757-1.089-.744.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.835 2.809 1.305 3.495.998.108-.775.42-1.305.762-1.605-2.665-.3-5.467-1.332-5.467-5.93 0-1.31.468-2.381 1.236-3.22-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.51 11.51 0 0 1 3-.404c1.02.005 2.048.138 3 .404 2.29-1.552 3.296-1.23 3.296-1.23.655 1.652.244 2.873.12 3.176.77.839 1.235 1.91 1.235 3.22 0 4.61-2.807 5.625-5.48 5.92.43.37.814 1.102.814 2.222v3.293c0 .322.216.694.825.576C20.565 21.796 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "Twitter / X",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.261 5.638L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>`,
  },
];
---

<footer id="footer" style="background: #F8F7F4; border-top: 1px solid #DEDBD5;">
  <div class="section-container py-20">

    <!-- Large CTA headline -->
    <div class="grid md:grid-cols-12 gap-8 items-end pb-16 border-b border-gray-200">
      <div class="md:col-span-8">
        <div class="eyebrow mb-4">Get in touch</div>
        <h2
          class="text-5xl md:text-7xl leading-tight"
          style="font-family: 'Playfair Display', serif; color: #111111;"
        >
          Let's build something
          <em style="color: #E63946;">great</em> together.
        </h2>
      </div>
      <div class="md:col-span-4 flex flex-col gap-4 items-start md:items-end">
        <!-- EDIT: Your actual email -->
        <a
          href="mailto:hello@alexdev.io"
          class="text-base md:text-lg font-semibold transition-colors duration-150 hover:text-red-600"
          style="font-family: 'Manrope', sans-serif; color: #111111;"
        >
          hello@alexdev.io
        </a>

        <!-- Social links -->
        <div class="flex items-center gap-3 mt-2">
          {socials.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              class="flex items-center justify-center w-9 h-9 border border-gray-300 text-gray-500 hover:text-gray-900 hover:border-gray-600 transition-all duration-150"
              set:html={social.icon}
            >
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8">
      <!-- Name / brand -->
      <!-- EDIT: Your name -->
      <span
        class="text-xl font-bold"
        style="font-family: 'Playfair Display', serif; color: #111111;"
      >
        Alex<span class="accent">.</span>
      </span>

      <span class="vol-text">© {new Date().getFullYear()} — All rights reserved.</span>

      <span class="vol-text">
        Built with{" "}
        <a href="https://astro.build" class="hover:text-gray-700 transition-colors">Astro</a>
        {" "}+{" "}
        <a href="https://tailwindcss.com" class="hover:text-gray-700 transition-colors">TailwindCSS</a>
      </span>
    </div>

  </div>
</footer>
