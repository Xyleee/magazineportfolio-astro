---
// About.astro — Editorial bio section
// EDIT: Replace placeholder text
---

<section id="about" class="py-20" style="background: #F8F7F4;">
  <div class="section-container">

    <!-- Section header row -->
    <div class="flex items-center gap-4 mb-10">
      <span class="eyebrow">About Me</span>
      <hr class="flex-1 rule" />
      <span class="vol-text">Page 02</span>
    </div>

    <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-start">

      <!-- Big pull headline (left, 5 cols) -->
      <div class="md:col-span-5">
        <!-- EDIT: Your section headline -->
        <h2
          class="text-4xl md:text-5xl leading-tight"
          style="font-family: 'Playfair Display', serif; color: #111111;"
        >
          I write code like I write
          <em style="color: #E63946;">stories</em> — with purpose.
        </h2>

        <!-- Magazine pull quote -->
        <blockquote
          class="mt-8 pl-5 italic text-lg leading-relaxed"
          style="border-left: 3px solid #E63946; color: #3D3D3D; font-family: 'Playfair Display', serif;"
        >
          <!-- EDIT: Your favorite quote -->
          "Code is poetry — every function tells a story, every bug is a plot twist."
          <cite class="block mt-3 not-italic vol-text" style="color: #777777;">— Me, debugging at midnight</cite>
        </blockquote>
      </div>

      <!-- Bio + Quick Facts (right, 7 cols) -->
      <div class="md:col-span-7 flex flex-col gap-8">

        <!-- Bio copy -->
        <!-- EDIT: Your bio paragraphs -->
        <div class="flex flex-col gap-5 text-base leading-relaxed" style="color: #3D3D3D; font-family: 'Inter', sans-serif; font-weight: 300;">
          <p>
            I'm a self-taught web developer who fell in love with the internet at age 14
            after inspecting the source code of a website for the first time. I specialize in
            <strong style="font-weight: 600; color: #111111;">frontend engineering</strong>
            with a healthy interest in backend systems and developer experience.
          </p>
          <p>
            When I'm not writing code, I'm probably reading about design systems,
            contributing to open-source, or building side projects that nobody asked for
            but somebody needed. I believe great software is about
            <strong style="font-weight: 600; color: #111111;">clarity and empathy</strong>
            as much as logic.
          </p>
        </div>

        <hr class="rule" />

        <!-- Quick facts — editorial table layout -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-6">
          <!-- EDIT: Your facts -->
          {[
            { label: "Years Coding", value: "3+" },
            { label: "Fav Language", value: "TypeScript" },
            { label: "Fav Framework", value: "Astro / Next.js" },
            { label: "Daily Fuel", value: "Black Coffee ×3" },
            { label: "Coding Playlist", value: "Lo-fi Hip Hop" },
            { label: "Based In", value: "Earth, GMT+8" },
          ].map((fact) => (
            <div class="flex flex-col gap-1">
              <div class="eyebrow">{fact.label}</div>
              <div class="text-sm font-semibold" style="font-family: 'Manrope', sans-serif; color: #111111;">{fact.value}</div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Section separator -->
<div class="section-container"><hr class="rule" /></div>
