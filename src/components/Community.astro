// Community.astro — Open source & community involvement
// EDIT: Replace with your actual contributions

const contributions = [
  {
    type: "Open Source",
    title: "Contributed to Astro",
    description: "Documentation improvements and bug fixes to the Astro framework, focusing on the Integration API.",
    link: "#",
  },
  {
    type: "Writing",
    title: "Dev.to Author",
    description: "12+ technical articles on web performance, CSS tricks, and Astro. 5,000+ readers reached.",
    link: "#",
  },
  {
    type: "Speaking",
    title: "Tech Talk: 'CSS at Scale'",
    description: "20-minute lightning talk at a local dev meetup on managing CSS in large component libraries.",
    link: "#",
  },
  {
    type: "Hackathons",
    title: "MLH Local Hack Day",
    description: "3 hackathons in 2023. Built a habit tracker, an accessibility checker, and a dev resource aggregator.",
    link: "#",
  },
  {
    type: "Mentoring",
    title: "CS50 Study Group",
    description: "Organized weekly online study groups for 20+ learners going through Harvard's CS50 curriculum.",
    link: "#",
  },
  {
    type: "Open Source",
    title: "Maintainer: tiny-color-utils",
    description: "Small npm utility library for color manipulation. 200+ weekly downloads, actively maintained.",
    link: "#",
  },
